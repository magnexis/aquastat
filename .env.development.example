AQUASTAT_ENVIRONMENT=development
AQUASTAT_PUBLIC_BASE_URL=http://localhost:8080
AQUASTAT_HOST=127.0.0.1
AQUASTAT_PORT=8080
AQUASTAT_LOG_LEVEL=debug
AQUASTAT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aquastat
AQUASTAT_DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aquastat
AQUASTAT_REDIS_ENABLED=false
AQUASTAT_CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
AQUASTAT_API_KEY_HASHES=[]
AQUASTAT_ADMIN_API_KEY_HASHES=[]
AQUASTAT_BILLING_ENABLED=false
AQUASTAT_CASH_APP_PAY_ENABLED=false
AQUASTAT_BILLING_SANDBOX_ONLY=true
AQUASTAT_BILLING_DEFAULT_CURRENCY=USD
AQUASTAT_BILLING_CHECKOUT_BASE_URL=http://localhost:8080
AQUASTAT_BILLING_SESSION_TTL_MINUTES=30
AQUASTAT_SQUARE_ENVIRONMENT=sandbox
AQUASTAT_SQUARE_API_VERSION=2026-07-16
AQUASTAT_SQUARE_APPLICATION_ID=
AQUASTAT_SQUARE_ACCESS_TOKEN=
AQUASTAT_SQUARE_LOCATION_ID=
AQUASTAT_SQUARE_WEBHOOK_SIGNATURE_KEY=
AQUASTAT_SQUARE_WEBHOOK_NOTIFICATION_URL=http://localhost:8080/api/v1/billing/webhooks/square
AQUASTAT_PUBLIC_SQUARE_APPLICATION_ID=
AQUASTAT_PUBLIC_SQUARE_LOCATION_ID=
