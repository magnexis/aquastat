AQUASTAT_ENVIRONMENT=production
AQUASTAT_APP_VERSION=1.0.0
AQUASTAT_PUBLIC_BASE_URL=https://aquastat-api.onrender.com
AQUASTAT_HOST=0.0.0.0
AQUASTAT_PORT=8080
AQUASTAT_LOG_LEVEL=info
AQUASTAT_DATABASE_URL=postgresql+asyncpg://aquastat_admin:replace-me@localhost:5433/aquastat_prod
AQUASTAT_DIRECT_DATABASE_URL=postgresql://aquastat_admin:replace-me@localhost:5433/aquastat_prod
AQUASTAT_REDIS_URL=redis://localhost:6379/0
AQUASTAT_REDIS_ENABLED=false
AQUASTAT_BOOTSTRAP_DATABASE_ON_STARTUP=false
AQUASTAT_TELEMETRY_REFRESH_INTERVAL_SECONDS=300
AQUASTAT_TRUST_PROXY=true
AQUASTAT_CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","https://magnexis.github.io","https://aquastat-api.onrender.com"]
AQUASTAT_ANONYMOUS_RATE_LIMIT_CAPACITY=60
AQUASTAT_ANONYMOUS_RATE_LIMIT_WINDOW_SECONDS=3600
AQUASTAT_DEVELOPER_RATE_LIMIT_CAPACITY=10000
AQUASTAT_DEVELOPER_RATE_LIMIT_WINDOW_SECONDS=86400
AQUASTAT_MAX_REQUEST_BODY_BYTES=5242880
AQUASTAT_REQUEST_TIMEOUT_SECONDS=15
AQUASTAT_SHUTDOWN_TIMEOUT_SECONDS=15
AQUASTAT_API_KEY_HASHES=["replace-with-generated-hash"]
AQUASTAT_ADMIN_API_KEY_HASHES=["replace-with-generated-admin-hash"]
AQUASTAT_ELECTRICITY_MAPS_API_KEY=
AQUASTAT_BILLING_ENABLED=false
AQUASTAT_CASH_APP_PAY_ENABLED=false
AQUASTAT_BILLING_SANDBOX_ONLY=true
AQUASTAT_BILLING_DEFAULT_CURRENCY=USD
AQUASTAT_BILLING_CHECKOUT_BASE_URL=https://aquastat-api.onrender.com
AQUASTAT_BILLING_SESSION_TTL_MINUTES=30
AQUASTAT_SQUARE_ENVIRONMENT=sandbox
AQUASTAT_SQUARE_API_VERSION=2026-07-16
AQUASTAT_SQUARE_APPLICATION_ID=
AQUASTAT_SQUARE_ACCESS_TOKEN=
AQUASTAT_SQUARE_LOCATION_ID=
AQUASTAT_SQUARE_WEBHOOK_SIGNATURE_KEY=
AQUASTAT_SQUARE_WEBHOOK_NOTIFICATION_URL=https://aquastat-api.onrender.com/api/v1/billing/webhooks/square
AQUASTAT_PUBLIC_SQUARE_APPLICATION_ID=
AQUASTAT_PUBLIC_SQUARE_LOCATION_ID=
