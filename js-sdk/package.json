{
  "name": "@aquastat/sdk",
  "version": "1.1.2",
  "description": "JavaScript SDK for AquaStat water-aware infrastructure APIs.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magnexis/aquastat.git"
  },
  "homepage": "https://aquastat-api.onrender.com/docs",
  "bugs": {
    "url": "https://github.com/magnexis/aquastat/issues"
  },
  "keywords": [
    "aquastat",
    "water",
    "api",
    "sdk",
    "infrastructure",
    "sustainability"
  ],
  "publishConfig": {
    "access": "public"
  }
}
