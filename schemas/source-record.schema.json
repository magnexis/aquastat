{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AquaStat Source Record",
  "type": "object",
  "required": ["id", "title", "publisher", "sourceType", "url", "publicationDate", "retrievedAt"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "publisher": { "type": "string" },
    "sourceType": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "documentType": { "type": ["string", "null"] },
    "publicationDate": { "type": "string", "format": "date" },
    "retrievedAt": { "type": "string", "format": "date-time" },
    "contentHash": { "type": ["string", "null"] },
    "license": { "type": ["string", "null"] },
    "jurisdiction": { "type": ["string", "null"] },
    "language": { "type": ["string", "null"] },
    "accessStatus": { "type": ["string", "null"] },
    "parserVersion": { "type": ["string", "null"] },
    "ingestionStatus": { "type": ["string", "null"] },
    "reviewStatus": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
