{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AquaStat Facility Import Row",
  "type": "object",
  "required": ["facility_name", "source_url", "source_type"],
  "properties": {
    "facility_name": { "type": "string", "minLength": 1 },
    "operator_name": { "type": "string" },
    "facility_type": { "type": "string" },
    "status": { "type": "string" },
    "country": { "type": "string" },
    "state": { "type": "string" },
    "municipality": { "type": "string" },
    "address": { "type": "string" },
    "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
    "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
    "capacity_mw": { "type": "number", "minimum": 0 },
    "capacity_type": { "type": "string" },
    "floor_area_sqft": { "type": "number", "minimum": 0 },
    "cooling_system": { "type": "string" },
    "pue": { "type": "number", "minimum": 1 },
    "wue_l_per_kwh": { "type": "number", "minimum": 0 },
    "annual_water_liters": { "type": "number", "minimum": 0 },
    "annual_electricity_mwh": { "type": "number", "minimum": 0 },
    "reporting_year": { "type": "integer", "minimum": 2000, "maximum": 2100 },
    "source_url": { "type": "string", "format": "uri" },
    "source_type": { "type": "string", "minLength": 1 },
    "source_date": { "type": "string", "format": "date" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
