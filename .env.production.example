AQUASTAT_ENVIRONMENT=production
AQUASTAT_PUBLIC_BASE_URL=https://aquastat-api.onrender.com
AQUASTAT_HOST=0.0.0.0
AQUASTAT_PORT=10000
AQUASTAT_LOG_LEVEL=info
AQUASTAT_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DATABASE?sslmode=require
AQUASTAT_DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
AQUASTAT_REDIS_ENABLED=false
AQUASTAT_TRUST_PROXY=true
AQUASTAT_CORS_ALLOWED_ORIGINS=["https://magnexis.github.io","https://aquastat-api.onrender.com"]
AQUASTAT_API_KEY_HASHES=["replace-with-generated-hash"]
AQUASTAT_ADMIN_API_KEY_HASHES=["replace-with-generated-admin-hash"]
AQUASTAT_BILLING_ENABLED=true
AQUASTAT_CASH_APP_PAY_ENABLED=true
AQUASTAT_BILLING_SANDBOX_ONLY=false
AQUASTAT_BILLING_DEFAULT_CURRENCY=USD
AQUASTAT_BILLING_CHECKOUT_BASE_URL=https://aquastat-api.onrender.com
AQUASTAT_BILLING_SESSION_TTL_MINUTES=30
AQUASTAT_SQUARE_ENVIRONMENT=production
AQUASTAT_SQUARE_API_VERSION=2026-07-16
AQUASTAT_SQUARE_APPLICATION_ID=
AQUASTAT_SQUARE_ACCESS_TOKEN=
AQUASTAT_SQUARE_LOCATION_ID=
AQUASTAT_SQUARE_WEBHOOK_SIGNATURE_KEY=
AQUASTAT_SQUARE_WEBHOOK_NOTIFICATION_URL=https://aquastat-api.onrender.com/api/v1/billing/webhooks/square
AQUASTAT_PUBLIC_SQUARE_APPLICATION_ID=
AQUASTAT_PUBLIC_SQUARE_LOCATION_ID=
